<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Wizard View -->
    <record id="view_import_iran_holidays_wizard_form" model="ir.ui.view">
        <field name="name">import.iran.holidays.wizard.form</field>
        <field name="model">import.iran.holidays.wizard</field>
        <field name="arch" type="xml">
            <form string="دریافت تعطیلات رسمی ایران">
                <group>
                    <group>
                        <field name="year"/>
                        <field name="month"/>
                    </group>

                    <group>
                        <field name="apply_all_calendars"/>
                        <field
                            name="calendar_ids"
                            widget="many2many_tags"
                            attrs="{'invisible': [('apply_all_calendars', '=', True)],
                                    'required': [('apply_all_calendars', '=', False)]}"
                        />
                    </group>
                </group>

                <group>
                    <field name="note" nolabel="1" readonly="1"/>
                </group>

                <footer>
                    <button
                        name="action_import"
                        type="object"
                        string="دریافت تعطیلات"
                        class="btn-primary"
                    />

                    <button
                        string="انصراف"
                        class="btn-secondary"
                        special="cancel"
                    />
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_import_iran_holidays" model="ir.actions.act_window">
        <field name="name">دریافت تعطیلات رسمی ایران</field>
        <field name="res_model">import.iran.holidays.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_import_iran_holidays"
        name="دریافت تعطیلات رسمی ایران"
        parent="hr_holidays.menu_hr_holidays_configuration"
        action="action_import_iran_holidays"
        sequence="100"
    />

</odoo>